datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_AUTH")
  schemas  = ["public"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

model Usuario {
  id    Int    @id @default(autoincrement())
  nome  String @db.VarChar(100)
  email String @db.VarChar(35) @unique
  senha String @db.VarChar(60)
  papel Papel  @default(CIDADAO)

  @@map("usuarios")
  @@schema("public")
}

enum Papel {
  CIDADAO
  GESTOR

  @@schema("public")
}