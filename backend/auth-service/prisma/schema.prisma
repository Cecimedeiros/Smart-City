datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL_AUTH")
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id    Int    @id @default(autoincrement())
  nome  String @db.VarChar(100)
  email String @db.VarChar(35) @unique
  senha String @db.VarChar(60)
  papel Papel  @default(CIDADAO)

  @@map("usuarios")
}

enum Papel {
  CIDADAO
  GESTOR
}