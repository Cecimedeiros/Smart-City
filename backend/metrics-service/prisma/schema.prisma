datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_DEMAND")
  schemas  = ["demand"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

model Denuncia {
  id_denuncia   Int             @id @default(autoincrement())
  titulo        String
  categoria     Categorias
  regiao        Regioes
  descricao     String
  status        StatusDenuncia  @default(ABERTA)
  prioridade    NivelPrioridade @default(MEDIA)
  data_registro DateTime        @default(now())
  endereco      String
  cidadao_id    Int

  @@index([categoria])
  @@index([status])
  @@index([prioridade])
  @@index([regiao])
  @@map("denuncias")
  @@schema("demand")
}

enum Categorias {
  ILUMINACAO_PUBLICA
  MANUTENCAO_DE_VIAS
  SANEAMENTO
  COLETA_DE_LIXO
  FISCALIZACAO
  SEGURANCA
  SINALIZACAO_DE_TRANSITO
  OUTROS_EMPECILHOS

  @@schema("demand")
}

enum Regioes {
  REGIAO_METROPOLITANA_DO_RECIFE
  ZONA_DA_MATA
  AGRESTE
  SERTAO
  OUTRA

  @@schema("demand")
}

enum StatusDenuncia {
  ABERTA
  EM_ANALISE
  RESOLVIDA

  @@schema("demand")
}

enum NivelPrioridade {
  ALTA
  MEDIA
  BAIXA

  @@schema("demand")
}
