# Copie este arquivo para .env.local e preencha os valores antes de subir o Docker
# O host do banco dentro do Docker é "postgres-db" (nome do serviço no docker-compose)

DATABASE_URL=postgresql://postgres:postgres@postgres-db:5432/smartcity
JWT_SECRET=change-me
REDIS_URL=redis://redis:6379
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smartcity
